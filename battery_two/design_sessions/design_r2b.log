for gen in $gens; do
  python3 "$gen" >/dev/null 2>&1
done
second="$(hash_outputs)"
[ "$first" = "$second" ]
printf '"'%s\\n' 'round-2 generators passed and regenerated bytes matched'" in /Users/alexanderking/Desktop/random_stuff/sol_trap_design
