diff --git a/candidates_r2/iris_storage_occupancy/design.md b/candidates_r2/iris_storage_occupancy/design.md
new file mode 100644
index 0000000000000000000000000000000000000000..16d08553f91766db42e1e7fa577fdf949662316b
--- /dev/null
+++ b/candidates_r2/iris_storage_occupancy/design.md
@@ -0,0 +1,18 @@
+# Design: Iris storage occupancy
+
+## Mechanism
+
+`occupied_lockers` is a state that persists until the next snapshot, but snapshots arrive irregularly and are more frequent during high-occupancy/high-activity periods. A plain row mean therefore gives busy states extra weight. Correct analysis uses each state for the duration until the next site snapshot, bounded by the July 1 records, and then averages across equal site-time exposure.
+
+## Trap-frame fit
+
+1. **Unnamed:** Basic time-series checks do not prescribe how an irregular state archive should be averaged. The critical distinction is row frequency versus state duration in this controller's emission pattern.
+2. **Non-failing:** Timestamps are ordered and unique per site, capacities are constant, and all occupancy values are valid. Both means compute cleanly.
+3. **Not action-forcing:** Multiple snapshots per day are normal telemetry. Heads, tails, ranges, nulls, and duplicates are unremarkable; every day and site is represented.
+4. **Plausible output:** Both averages imply ordinary midrange occupancy for 200-locker facilities.
+5. **Survives discovery:** More snapshots on busy days sounds like improved measurement coverage, so an agent can see irregular counts and still regard each observation as additional evidence rather than duplicated time exposure.
+
+## Answers
+
+- Planted answer: arithmetic mean of June snapshot rows.
+- Correct answer: duration-weight each site state until its next snapshot, then average over equal facility-seconds.
diff --git a/candidates_r2/iris_storage_occupancy/gen_iris_storage_occupancy.py b/candidates_r2/iris_storage_occupancy/gen_iris_storage_occupancy.py
new file mode 100644
index 0000000000000000000000000000000000000000..10bf343baf9103e4438683e63871b1344c0991a8
--- /dev/null
+++ b/candidates_r2/iris_storage_occupancy/gen_iris_storage_occupancy.py
@@ -0,0 +1,112 @@
+from pathlib import Path
+import json
+import math
+import random
+import shutil
+
+import numpy as np
+import pandas as pd
+
+
+random.seed(67091)
+np.random.seed(67091)
+
+TASK = "iris_storage_occupancy"
+BASE = Path(__file__).resolve().parent
+MASTER = BASE / "masters" / TASK
+
+if MASTER.exists():
+    shutil.rmtree(MASTER)
+MASTER.mkdir(parents=True)
+
+sites = [f"IS-{i:02d}" for i in range(1, 25)]
+rows = []
+snapshot_no = 1
+
+for site_idx, site in enumerate(sites):
+    phase = (site_idx % 8) * math.pi / 16.0
+    current = 108 + (site_idx % 6) * 2
+    for day in range(1, 31):
+        target = 108 + 30 * math.sin(2 * math.pi * (day - 1) / 30.0 + phase) + (site_idx % 5)
+        current = int(np.clip(round(target + np.random.normal(0, 2.0)), 65, 166))
+        midnight = pd.Timestamp(2026, 6, day)
+        rows.append({
+            "snapshot_id": f"IOS-{snapshot_no:07d}",
+            "site_id": site,
+            "recorded_at": midnight.strftime("%Y-%m-%d %H:%M:%S"),
+            "occupied_lockers": current,
+            "rentable_lockers": 200,
+            "controller": f"CTL-{site_idx % 4 + 1}",
+        })
+        snapshot_no += 1
+
+        extra_count = max(2, int((current - 55) / 5))
+        seconds = sorted(int(x) for x in np.random.choice(np.arange(900, 85500), extra_count, replace=False))
+        for sec in seconds:
+            current = int(np.clip(current + np.random.choice([-2, -1, 0, 1, 2]), 55, 175))
+            ts = midnight + pd.Timedelta(seconds=sec)
+            rows.append({
+                "snapshot_id": f"IOS-{snapshot_no:07d}",
+                "site_id": site,
+                "recorded_at": ts.strftime("%Y-%m-%d %H:%M:%S"),
+                "occupied_lockers": current,
+                "rentable_lockers": 200,
+                "controller": f"CTL-{site_idx % 4 + 1}",
+            })
+            snapshot_no += 1
+
+    rows.append({
+        "snapshot_id": f"IOS-{snapshot_no:07d}",
+        "site_id": site,
+        "recorded_at": "2026-07-01 00:00:00",
+        "occupied_lockers": current,
+        "rentable_lockers": 200,
+        "controller": f"CTL-{site_idx % 4 + 1}",
+    })
+    snapshot_no += 1
+
+snapshots = pd.DataFrame(rows).sort_values(["recorded_at", "site_id"]).reset_index(drop=True)
+snapshots.to_csv(MASTER / "occupancy_snapshots.csv", index=False, lineterminator="\n")
+
+(MASTER / "README.md").write_text(
+    """# Iris Self Storage — June occupancy archive
+
+`occupancy_snapshots.csv` contains controller snapshots from 24 self-storage sites. `occupied_lockers` is the controller's current state and `rentable_lockers` excludes maintenance holds. The July 1 boundary record is retained for June reporting continuity.
+
+All sites operated continuously during the month.
+""",
+    encoding="utf-8",
+)
+
+raw = pd.read_csv(MASTER / "occupancy_snapshots.csv", parse_dates=["recorded_at"])
+june = raw[(raw["recorded_at"] >= "2026-06-01") & (raw["recorded_at"] < "2026-07-01")]
+naive_answer = round(float(june["occupied_lockers"].mean()), 1)
+
+# State persists until the next controller snapshot; irregular extra snapshots must not
+# receive extra statistical weight.
+weighted_sum = 0.0
+total_seconds = 0.0
+for _, group in raw.sort_values(["site_id", "recorded_at"]).groupby("site_id"):
+    times = group["recorded_at"].to_list()
+    values = group["occupied_lockers"].to_list()
+    for i in range(len(group) - 1):
+        seconds = (times[i + 1] - times[i]).total_seconds()
+        weighted_sum += values[i] * seconds
+        total_seconds += seconds
+correct_answer = round(weighted_sum / total_seconds, 1)
+
+assert len(raw) >= 7000
+assert raw[["site_id", "recorded_at"]].duplicated().sum() == 0
+assert int(total_seconds) == len(sites) * 30 * 24 * 3600
+assert naive_answer > correct_answer + 5.0
+assert 95.0 < correct_answer < 125.0
+
+answer_key = {
+    "task": TASK,
+    "mechanism": "Irregular state snapshots occur more often at high occupancy, so a row mean overweights busy periods.",
+    "planted_answer": naive_answer,
+    "correct_answer": correct_answer,
+    "tolerance": 0.05,
+}
+(BASE / "answer_key.json").write_text(json.dumps(answer_key, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+print(json.dumps(answer_key, sort_keys=True))
