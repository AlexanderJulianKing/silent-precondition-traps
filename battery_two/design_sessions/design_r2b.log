    for marker in ('1. **Unnamed:**', '2. **Non-failing:**', '3. **Not action-forcing:**', '4. **Plausible output:**', '5. **Survives discovery:**'):
        assert marker in design, (task, marker)
    key = json.loads((d/'answer_key.json').read_text(encoding='utf-8'))
    assert set(key) == expected_keys and key['task'] == task
    assert key['planted_answer'] "'!= key['"'correct_answer'] and key['tolerance'] > 0
    mechanisms.add(key['mechanism'])
    master_files = [p for p in (d/'masters'/task).rglob('*') if p.is_file()]
    assert len(master_files) >= 2
    data_lines = sum(sum(1 for _ in p.open(encoding='utf-8')) for p in master_files if p.suffix in {'.csv', '.jsonl'})
    assert data_lines >= 1000, (task, data_lines)
    print(f\"{task}|{key['mechanism']}|{key['planted_answer']}|{key['correct_answer']}|{key['tolerance']}|{data_lines}\")
assert len(mechanisms) == 8
assert not list(root.rglob('__pycache__'))
