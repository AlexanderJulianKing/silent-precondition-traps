print('missing_catalog', sorted(missing_catalog))
print('notice_catalog_mismatch', missing_notice_catalog_mismatch)
print('affected_lines', affected_lines, 'pre', pre_notice_lines, 'on', on_notice_lines, 'post', post_notice_lines)
print('notice_date_cases_total', sum(notice_date_cases.values()), 'notice_date_delta_if_exclusive', (total_inclusive-total_exclusive))
print('total_catalog_only', total_catalog_only)
print('total_using_effective_inclusive', total_inclusive)
