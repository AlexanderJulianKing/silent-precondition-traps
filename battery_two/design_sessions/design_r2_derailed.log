with open('supplier_item_notices.csv', newline='') as f:
    notices = {r['sku']: r for r in csv.DictReader(f)}

missing_catalog = set()
missing_notice_catalog_mismatch = []
line_count = 0
dates = []
total_inclusive = 0
total_exclusive = 0
total_catalog_only = 0
affected_lines = 0
pre_notice_lines = 0
on_notice_lines = 0
post_notice_lines = 0
by_month = Counter()
by_sku_cases = Counter()
notice_date_cases = Counter()

with open('q2_shipment_lines.csv', newline='') as f:
    for r in csv.DictReader(f):
        line_count += 1
        sku = r['sku']
        date = r['ship_date']
        cases = int(r['cases_shipped'])
        dates.append(date)
        if sku not in catalog:
            missing_catalog.add(sku)
            continue
        catalog_units = catalog[sku]
        units_incl = catalog_units
        units_excl = catalog_units
        if sku in notices:
            n = notices[sku]
            prior = int(n['prior_units_per_case'])
            new = int(n['new_units_per_case'])
            eff = n['effective_ship_date']
            if catalog_units "'!= new:
                missing_notice_catalog_mismatch.append((sku, catalog_units, new))
            affected_lines += 1
            if date < eff:
                units_incl = prior
                units_excl = prior
                pre_notice_lines += 1
            elif date == eff:
                units_incl = new
                units_excl = prior
                on_notice_lines += 1
                notice_date_cases[sku] += cases
            else:
                units_incl = new
                units_excl = new
                post_notice_lines += 1
        total_inclusive += cases * units_incl
        total_exclusive += cases * units_excl
        total_catalog_only += cases * catalog_units
        by_month[date[:7]] += cases * units_incl
        by_sku_cases[sku] += cases

print('"'line_count', line_count)
