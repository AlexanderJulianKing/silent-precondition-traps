import csv
from collections import defaultdict
from decimal import Decimal

path = 'drawer_cash_audits.csv'
denom_values_cents = {
    'ones': 100,
    'fives': 500,
    'tens': 1000,
    'twenties': 2000,
    'fifties': 5000,
    'hundreds': 10000,
    'coins_cents': 1,
}
state = {}
rows_by_date = defaultdict(int)
drawers_by_date = defaultdict(set)
statuses = defaultdict(set)
missing_before_state = []
close_total_cents = 0
close_rows = []

with open(path, newline='') as f:
    reader = csv.DictReader(f)
    for line_no, row in enumerate(reader, start=2):
        drawer = row['drawer_id']
        if drawer not in state:
            state[drawer] = {}
        for field in denom_values_cents:
            raw = row[field]
            if raw "'!= '"'':
                state[drawer][field] = int(raw)
            elif field not in state[drawer]:
                missing_before_state.append((line_no, drawer, field))
        rows_by_date[row['audit_date']] += 1
        drawers_by_date[row['audit_date']].add(drawer)
        statuses[row['audit_date']].add(row['audit_status'])
        if row['audit_date'] == '2026-06-30':
            cents = sum(state[drawer][field] * value for field, value in denom_values_cents.items())
            close_total_cents += cents
            close_rows.append((drawer, cents, dict(state[drawer])))

print('missing_before_state', len(missing_before_state))
print('dates', min(rows_by_date), max(rows_by_date), len(rows_by_date))
print('rows_on_2026-06-30', rows_by_date['2026-06-30'])
print('drawers_on_2026-06-30', len(drawers_by_date['2026-06-30']))
print('statuses_on_2026-06-30', sorted(statuses['2026-06-30']))
print('total_cents', close_total_cents)
print('total_dollars', f'{close_total_cents/100:.2f}')
print('first_three_close_rows', [(d, f'{c/100:.2f}', s) for d,c,s in close_rows[:3]])
