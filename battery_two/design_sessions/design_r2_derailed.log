by_sku_wh={}
with open(stock,newline='') as f:
    for r in csv.DictReader(f):
        e=int(r['erp_qty']); c=int(r['counted_qty'])
        erp+=e; count+=c
        d=e-c
        if d>0: pos_short += d
        elif d<0: neg_over += -d
        by_sku_wh[(r['sku'],r['warehouse'])]=[e,c]
transfer_units=0
inbound=defaultdict(int); outbound=defaultdict(int)
statuses=defaultdict(int)
with open(trans,newline='') as f:
    for r in csv.DictReader(f):
        u=int(r['units'])
        transfer_units += u
        inbound[(r['sku'],r['to_warehouse'])]+=u
        outbound[(r['sku'],r['from_warehouse'])]+=u
        statuses[r['status']]+=1

# adjust expected physical on hand by subtracting inbound open transfers from destination ERP qty.
adj_expected=0
adj_missing_sum_pos=0
adj_over_sum_pos=0
examples=[]
for k,(e,c) in by_sku_wh.items():
    exp=e-inbound[k]
    adj_expected += exp
    d=exp-c
    if d>0: adj_missing_sum_pos += d
    elif d<0: adj_over_sum_pos += -d
    if inbound[k] and len(examples)<10:
        examples.append((k,e,c,inbound[k],exp,d))

print('rows', len(by_sku_wh))
print('erp_total', erp)
print('counted_total', count)
print('raw_net_missing', erp-count)
print('raw_pos_shortages', pos_short, 'raw_overages', neg_over)
print('transfer_units', transfer_units, 'statuses', dict(statuses))
print('adj_expected_total=erp-inbound', adj_expected)
print('adj_net_missing=adj_expected-counted', adj_expected-count)
print('adj_pos_missing', adj_missing_sum_pos, 'adj_overages', adj_over_sum_pos)
print('pct_net', (adj_expected-count)/adj_expected*100)
print('pct_pos', adj_missing_sum_pos/adj_expected*100)
print('examples')
for x in examples:
    print(x)
