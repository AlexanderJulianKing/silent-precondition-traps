import csv
from collections import Counter, defaultdict
from decimal import Decimal, ROUND_HALF_UP

orders='orders_june.csv'
timecards='timecards_june.csv'

status_counts=Counter()
order_dates=Counter()
with open(orders, newline='') as f:
    for r in csv.DictReader(f):
        status_counts[r['status']] += 1
        order_dates[r['order_date'][:7]] += 1

approval_counts=Counter()
minute_parts=Counter()
total_decimal=Decimal('0')
total_hhmm_minutes=0
rows=0
by_month=Counter()
with open(timecards, newline='') as f:
    for r in csv.DictReader(f):
        rows += 1
        approval_counts[r['approval_status']] += 1
        by_month[r['work_date'][:7]] += 1
        dur = r['paid_duration']
        total_decimal += Decimal(dur)
        h, _, frac = dur.partition('.')
        frac = (frac + '00')[:2]
        minute_parts[frac] += 1
        minutes = int(h) * 60 + int(frac)
        if int(frac) >= 60:
            print('bad minute part', dur)
        total_hhmm_minutes += minutes

fulfilled=status_counts['FULFILLED']
hours_hhmm=Decimal(total_hhmm_minutes)/Decimal(60)
ratio=Decimal(fulfilled)/hours_hhmm
ratio_rounded=ratio.quantize(Decimal('0.01'), rounding=ROUND_HALF_UP)
ratio_decimal=Decimal(fulfilled)/total_decimal
print('order status counts', status_counts)
print('order months', order_dates)
print('timecard approval counts', approval_counts)
print('timecard months', by_month)
